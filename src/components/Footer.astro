---
import SocialLinks from '~/components/SocialLinks.astro';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap">
    <div class="cols">
      <div>
        <a class="brand" href="/" style="margin-bottom:14px; display:inline-flex">
          <span class="brand-mark"></span>
          <span class="brand-name">leonardopegollo<span class="muted">.dev</span></span>
        </a>
        <p style="max-width:480px; margin-top:14px">
          Sito personale di Leonardo Pegollo. Medico di distretto a Milano,
          mani anche dentro il codice. Nessun cookie di tracciamento, nessun
          analytics di terze parti.
        </p>
        <div style="margin-top:18px">
          <SocialLinks variant="pills" />
        </div>
      </div>
      <div>
        <h5>Sezioni</h5>
        <p><a href="/">Home</a></p>
        <p><a href="/mediflow">MediFlow</a></p>
        <p><a href="/blog">Blog</a></p>
        <p><a href="/about">Chi sono</a></p>
      </div>
      <div>
        <h5>Sottoscrivi</h5>
        <p><a href="/rss.xml">RSS del blog</a></p>
      </div>
    </div>
    <div class="bottom">
      <span>© {year} Leonardo Pegollo · contenuti distribuiti come progetto personale</span>
      <span>Costruito con Astro · pubblicato su Cloudflare Pages</span>
    </div>
  </div>
</footer>
