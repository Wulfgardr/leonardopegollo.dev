---
// Intestazione di sezione ricorrente: kicker (label mono) + titolo + lead.
// Sostituisce il blocco ripetuto a mano in home e white paper.
interface Props {
  kicker: string;
  heading: string;
  lead?: string;
  reveal?: boolean;
}
const { kicker, heading, lead, reveal = true } = Astro.props;
---
<div class:list={['section-head', { reveal }]}>
  <div class="kicker">{kicker}</div>
  <h2>{heading}</h2>
  {lead && <p class="lead">{lead}</p>}
  <slot />
</div>
