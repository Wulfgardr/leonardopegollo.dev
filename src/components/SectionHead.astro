---
// Intestazione di sezione: titolo + lead. Niente kicker/eyebrow decorativi.
interface Props {
  heading: string;
  lead?: string;
  reveal?: boolean;
}
const { heading, lead, reveal = true } = Astro.props;
---
<div class:list={['section-head', { reveal }]}>
  <h2>{heading}</h2>
  {lead && <p class="lead">{lead}</p>}
  <slot />
</div>
