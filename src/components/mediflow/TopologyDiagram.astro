---
// Diagramma di topologia MediFlow: SVG disegnato a mano + legenda + tema scuro.
// Co-locato con le sue regole CSS (incluse le sovrascritture di colore per il
// pannello scuro), così è modificabile in isolamento.
interface Props {
  reveal?: boolean;
}
const { reveal = true } = Astro.props;
---
<div class:list={['topo', { reveal }]}>
  <svg viewBox="0 0 1100 560" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="topo-title topo-desc">
    <title id="topo-title">Topologia di MediFlow</title>
    <desc id="topo-desc">
      Tutto gira sul Mac di chi cura. I client (browser, client macOS, iPhone/iPad accoppiati)
      parlano con un'unica applicazione locale tramite un proxy TLS su 127.0.0.1 e tre superfici
      API (Web, Native versionata, Network opzionale per i client paired in LAN). I servizi locali
      opzionali — Ollama per AI e OCR, ICD-11 OMS in docker, redazione OpenMed in sola valutazione —
      sono sempre su localhost. Il filesystem locale contiene il database SQLite cifrato medical.db,
      il backup notturno, il token API e i certificati TLS. La cifratura deriva la chiave dal PIN
      (PIN → KEK → master key in RAM, AES-256-GCM), e il PIN non viene mai persistito.
    </desc>
    <defs>
      <linearGradient id="g-client" x1="0" x2="1" y1="0" y2="1"><stop offset="0%" stop-color="#8fa2b2" stop-opacity=".18"/><stop offset="100%" stop-color="#8fa2b2" stop-opacity=".04"/></linearGradient>
      <linearGradient id="g-back" x1="0" x2="1" y1="0" y2="1"><stop offset="0%" stop-color="#15c47a" stop-opacity=".20"/><stop offset="100%" stop-color="#0e6e5c" stop-opacity=".06"/></linearGradient>
      <linearGradient id="g-svc" x1="0" x2="1" y1="0" y2="1"><stop offset="0%" stop-color="#426b7f" stop-opacity=".20"/><stop offset="100%" stop-color="#426b7f" stop-opacity=".04"/></linearGradient>
      <linearGradient id="g-fs" x1="0" x2="1" y1="0" y2="1"><stop offset="0%" stop-color="#8a6a2b" stop-opacity=".18"/><stop offset="100%" stop-color="#8a6a2b" stop-opacity=".04"/></linearGradient>
      <marker id="arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M0,0 L10,5 L0,10 Z" fill="#52616d"/></marker>
    </defs>

    <rect x="20" y="20" width="280" height="520" rx="18" fill="url(#g-client)" stroke="rgba(143,162,178,.32)"/>
    <text x="36" y="50" fill="#8fa2b2" font-size="12" font-family="ui-monospace" letter-spacing="0" font-weight="600">CLIENT</text>

    <rect x="320" y="20" width="320" height="520" rx="18" fill="url(#g-back)" stroke="rgba(21,196,122,.34)"/>
    <text x="336" y="50" fill="#15c47a" font-size="12" font-family="ui-monospace" letter-spacing="0" font-weight="600">APPLICAZIONE LOCALE</text>

    <rect x="660" y="20" width="220" height="260" rx="18" fill="url(#g-svc)" stroke="rgba(66,107,127,.36)"/>
    <text x="676" y="50" fill="#8fb8c9" font-size="12" font-family="ui-monospace" letter-spacing="0" font-weight="600">SERVIZI LOCALI</text>

    <rect x="660" y="295" width="420" height="245" rx="18" fill="url(#g-fs)" stroke="rgba(138,106,43,.34)"/>
    <text x="676" y="325" fill="#c79a45" font-size="12" font-family="ui-monospace" letter-spacing="0" font-weight="600">FILESYSTEM LOCALE</text>

    <rect x="900" y="20" width="180" height="260" rx="18" fill="rgba(230,237,243,.03)" stroke="rgba(230,237,243,.18)" stroke-dasharray="4 4"/>
    <text x="916" y="50" fill="#8d8a7d" font-size="12" font-family="ui-monospace" letter-spacing="0" font-weight="600">RETE LOCALE</text>
    <text x="916" y="68" fill="#5d5a51" font-size="11" font-family="ui-monospace">opt-in</text>

    <g font-family="-apple-system,Inter,sans-serif" fill="#f1ead9">
      <rect x="40" y="80" width="240" height="64" rx="14" fill="rgba(156,197,224,.16)" stroke="rgba(156,197,224,.4)"/>
      <text x="160" y="108" text-anchor="middle" font-size="14" font-weight="600">Browser web</text>
      <text x="160" y="128" text-anchor="middle" font-size="11" fill="#c8c3b3">UI clinica · cifratura lato client</text>

      <rect x="40" y="170" width="240" height="64" rx="14" fill="rgba(156,197,224,.12)" stroke="rgba(156,197,224,.36)"/>
      <text x="160" y="198" text-anchor="middle" font-size="14" font-weight="600">Client macOS</text>
      <text x="160" y="218" text-anchor="middle" font-size="11" fill="#c8c3b3">SwiftUI · sessione sicurezza</text>

      <rect x="40" y="260" width="240" height="64" rx="14" fill="rgba(156,197,224,.07)" stroke="rgba(156,197,224,.28)" stroke-dasharray="3 3"/>
      <text x="160" y="288" text-anchor="middle" font-size="14" font-weight="600">iPhone / iPad</text>
      <text x="160" y="308" text-anchor="middle" font-size="11" fill="#8d8a7d">paired · scrittura limitata</text>

      <rect x="40" y="380" width="240" height="130" rx="14" fill="rgba(241,234,217,.025)" stroke="rgba(241,234,217,.14)" stroke-dasharray="2 4"/>
      <text x="160" y="406" text-anchor="middle" font-size="12" fill="#8d8a7d" font-family="ui-monospace" letter-spacing="0">CIFRATURA</text>
      <text x="160" y="430" text-anchor="middle" font-size="13" fill="#c8c3b3">PIN → KEK</text>
      <text x="160" y="452" text-anchor="middle" font-size="13" fill="#c8c3b3">KEK → master key in RAM</text>
      <text x="160" y="474" text-anchor="middle" font-size="13" fill="#c8c3b3">AES-256-GCM</text>
      <text x="160" y="496" text-anchor="middle" font-size="11" fill="#5d5a51">PIN mai persistito</text>
    </g>

    <g font-family="-apple-system,Inter,sans-serif" fill="#f1ead9">
      <rect x="340" y="80" width="280" height="50" rx="12" fill="rgba(134,211,177,.14)" stroke="rgba(134,211,177,.38)"/>
      <text x="480" y="100" text-anchor="middle" font-size="13" font-weight="600">Proxy TLS locale</text>
      <text x="480" y="118" text-anchor="middle" font-size="11" fill="#c8c3b3">https://127.0.0.1:3443</text>

      <rect x="340" y="150" width="280" height="50" rx="12" fill="rgba(134,211,177,.14)" stroke="rgba(134,211,177,.38)"/>
      <text x="480" y="170" text-anchor="middle" font-size="13" font-weight="600">Web API · /api/*</text>
      <text x="480" y="188" text-anchor="middle" font-size="11" fill="#c8c3b3">sessione cookie</text>

      <rect x="340" y="220" width="280" height="50" rx="12" fill="rgba(134,211,177,.14)" stroke="rgba(134,211,177,.38)"/>
      <text x="480" y="240" text-anchor="middle" font-size="13" font-weight="600">Native API · /api/v1/*</text>
      <text x="480" y="258" text-anchor="middle" font-size="11" fill="#c8c3b3">bearer token versionato</text>

      <rect x="340" y="290" width="280" height="50" rx="12" fill="rgba(134,211,177,.08)" stroke="rgba(134,211,177,.28)" stroke-dasharray="3 3"/>
      <text x="480" y="310" text-anchor="middle" font-size="13" font-weight="600">Network API · /api/v1/network/*</text>
      <text x="480" y="328" text-anchor="middle" font-size="11" fill="#8d8a7d">paired · read-only-first</text>

      <rect x="340" y="370" width="280" height="60" rx="12" fill="rgba(134,211,177,.16)" stroke="rgba(134,211,177,.42)"/>
      <text x="480" y="394" text-anchor="middle" font-size="13" font-weight="600">Auth · setup / login / lockout</text>
      <text x="480" y="414" text-anchor="middle" font-size="11" fill="#c8c3b3">5 tentativi · 15 min</text>

      <rect x="340" y="450" width="280" height="60" rx="12" fill="rgba(134,211,177,.10)" stroke="rgba(134,211,177,.32)"/>
      <text x="480" y="474" text-anchor="middle" font-size="13" font-weight="600">Audit append-only</text>
      <text x="480" y="494" text-anchor="middle" font-size="11" fill="#c8c3b3">catalogo eventi limitato</text>
    </g>

    <g font-family="-apple-system,Inter,sans-serif" fill="#f1ead9">
      <rect x="680" y="80" width="180" height="50" rx="12" fill="rgba(179,168,216,.14)" stroke="rgba(179,168,216,.38)"/>
      <text x="770" y="102" text-anchor="middle" font-size="12.5" font-weight="600">Ollama</text>
      <text x="770" y="119" text-anchor="middle" font-size="10.5" fill="#c8c3b3">AI · OCR · :11434</text>

      <rect x="680" y="150" width="180" height="50" rx="12" fill="rgba(179,168,216,.14)" stroke="rgba(179,168,216,.38)"/>
      <text x="770" y="172" text-anchor="middle" font-size="12.5" font-weight="600">ICD-11 OMS</text>
      <text x="770" y="189" text-anchor="middle" font-size="10.5" fill="#c8c3b3">docker locale · :8888</text>

      <rect x="680" y="220" width="180" height="50" rx="12" fill="rgba(179,168,216,.08)" stroke="rgba(179,168,216,.28)" stroke-dasharray="3 3"/>
      <text x="770" y="242" text-anchor="middle" font-size="12.5" font-weight="600">OpenMed redaction</text>
      <text x="770" y="259" text-anchor="middle" font-size="10.5" fill="#8d8a7d">shadow · benchmark only</text>
    </g>

    <g font-family="-apple-system,Inter,sans-serif" fill="#f1ead9">
      <rect x="680" y="340" width="180" height="60" rx="12" fill="rgba(227,176,114,.16)" stroke="rgba(227,176,114,.42)"/>
      <text x="770" y="364" text-anchor="middle" font-size="13" font-weight="600">medical.db</text>
      <text x="770" y="384" text-anchor="middle" font-size="11" fill="#c8c3b3">SQLite cifrato</text>

      <rect x="880" y="340" width="180" height="60" rx="12" fill="rgba(227,176,114,.12)" stroke="rgba(227,176,114,.38)"/>
      <text x="970" y="364" text-anchor="middle" font-size="13" font-weight="600">backup notturno</text>
      <text x="970" y="384" text-anchor="middle" font-size="11" fill="#c8c3b3">retention configurabile</text>

      <rect x="680" y="420" width="180" height="60" rx="12" fill="rgba(227,176,114,.10)" stroke="rgba(227,176,114,.32)"/>
      <text x="770" y="444" text-anchor="middle" font-size="13" font-weight="600">token API locale</text>
      <text x="770" y="464" text-anchor="middle" font-size="11" fill="#c8c3b3">permessi 0600</text>

      <rect x="880" y="420" width="180" height="60" rx="12" fill="rgba(227,176,114,.10)" stroke="rgba(227,176,114,.32)"/>
      <text x="970" y="444" text-anchor="middle" font-size="13" font-weight="600">certificati TLS</text>
      <text x="970" y="464" text-anchor="middle" font-size="11" fill="#c8c3b3">cert.pem + key.pem</text>
    </g>

    <g font-family="-apple-system,Inter,sans-serif" fill="#c8c3b3">
      <rect x="920" y="80" width="140" height="50" rx="12" fill="rgba(241,234,217,.03)" stroke="rgba(241,234,217,.2)" stroke-dasharray="3 3"/>
      <text x="990" y="102" text-anchor="middle" font-size="12.5" font-weight="600" fill="#f1ead9">Mac home-base</text>
      <text x="990" y="119" text-anchor="middle" font-size="10.5">nodo autorevole</text>

      <rect x="920" y="150" width="140" height="50" rx="12" fill="rgba(241,234,217,.03)" stroke="rgba(241,234,217,.18)" stroke-dasharray="3 3"/>
      <text x="990" y="172" text-anchor="middle" font-size="12.5" font-weight="600" fill="#f1ead9">paired client</text>
      <text x="990" y="189" text-anchor="middle" font-size="10.5">capability + version</text>
    </g>

    <g stroke="#c8c3b3" stroke-width="1.2" fill="none" opacity=".6" marker-end="url(#arr)">
      <path d="M280 112 C 310 112 310 175 340 175"/>
      <path d="M280 202 C 310 202 310 105 340 105"/>
      <path d="M280 292 C 310 292 310 315 340 315"/>
      <path d="M620 175 C 650 175 650 105 680 105"/>
      <path d="M620 175 C 650 175 650 175 680 175"/>
      <path d="M620 245 C 650 245 650 245 680 245"/>
      <path d="M620 380 C 650 380 650 370 680 370"/>
      <path d="M860 370 L 880 370"/>
    </g>
  </svg>
  <div class="legend">
    <span><span class="swatch" style="background:#8fa2b2" aria-hidden="true"></span>Client</span>
    <span><span class="swatch" style="background:#15c47a" aria-hidden="true"></span>Applicazione locale</span>
    <span><span class="swatch" style="background:#426b7f" aria-hidden="true"></span>Servizi locali (opzionali)</span>
    <span><span class="swatch" style="background:#8a6a2b" aria-hidden="true"></span>Filesystem</span>
    <span><span class="swatch" style="background:#8b949d" aria-hidden="true"></span>Rete locale (opt-in)</span>
  </div>
</div>

<style>
  .topo{
    position:relative;
    padding:14px;
    border-radius:var(--r-media);
    background:var(--surface);
    border:1px solid var(--line);
    overflow:hidden;
    box-shadow:var(--sh-card);
  }
  .topo svg{
    width:100%;
    height:auto;
    display:block;
    padding:16px;
    border-radius:calc(var(--r-media) - 4px);
    background:#0d1117;
  }
  .topo svg [fill="#f1ead9"]{ fill:#e6edf3; }
  .topo svg [fill="#c8c3b3"]{ fill:#a8b0b8; }
  .topo svg [fill="#8d8a7d"]{ fill:#8b949d; }
  .topo svg [fill="#5d5a51"]{ fill:#6f7a84; }
  .topo svg [stroke="#c8c3b3"]{ stroke:#52616d; }
  .legend{
    display:flex; gap:18px; flex-wrap:wrap;
    margin-top:12px; padding:0 4px 2px;
    font-family:var(--font-technical); font-size:12px;
    color:var(--ink-1);
  }
  .legend .swatch{
    width:10px; height:10px; border-radius:999px;
    display:inline-block; vertical-align:middle; margin-right:8px;
  }
</style>
