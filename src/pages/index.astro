---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SocialLinks from '~/components/SocialLinks.astro';
import SectionHead from '~/components/SectionHead.astro';
import PullQuote from '~/components/PullQuote.astro';
import { getCollection } from 'astro:content';

// Ultimi tre post del blog, in ordine di data decrescente.
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="leonardopegollo.dev"
  description="Leonardo Pegollo: medico di distretto a Milano. Sanità territoriale, dati, software clinico locale e tecnologia usata con giudizio."
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy reveal">
        <p class="role-line">Medico di distretto · Milano</p>
        <h1 class="gradient-title">Leonardo Pegollo <span class="h-mute">medico, dati e lavoro clinico oggi.</span></h1>
        <p class="lead">
          Faccio il medico di distretto. Lavoro con pazienti complessi,
          domiciliarità e sanità territoriale; quando un problema ritorna spesso,
          provo a rimetterlo in ordine: dati, codice quando serve, un modo più
          ripetibile di arrivare a una risposta. Da lì nasce
          <a href="/mediflow" class="link-ink">MediFlow</a>, una cartella clinica
          <span class="sig">locale</span> che tiene i dati sul computer di chi cura.
        </p>
        <p class="lead muted">
          Nel lavoro clinico di oggi gli strumenti contano: prevenzione, medicina
          d'iniziativa, codice assistito dall'AI. Possono accorciare la distanza fra
          dati, persone e decisioni, ma chiedono umiltà e revisione. Se servono
          solo a produrre contenuto, hanno già perso il punto.
        </p>
        <div class="hero-notes" aria-label="Coordinate del sito">
          <span>Lavoro clinico</span>
          <span>Dati</span>
          <span>Software locale</span>
          <span>Note tecniche</span>
        </div>
        <div class="cta-row">
          <a class="btn btn-primary" href="/mediflow">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h4l2 5 3-10 2 5h7" /></svg>
            Leggi MediFlow
          </a>
          <a class="btn btn-ghost" href="/blog">Blog</a>
          <a class="btn btn-ghost" href="/about">Bio</a>
        </div>
        <div class="social-row">
          <SocialLinks variant="pills" />
        </div>
      </div>

      <article id="appunto" class="artifact reveal" aria-label="Appunto operativo sintetico · dati dimostrativi">
        <div class="artifact-shell">
          <header class="artifact-head">
            <div class="artifact-title">
              <strong>Appunto operativo</strong>
              <span>traccia sintetica · dati dimostrativi</span>
            </div>
            <span class="status-pill"><span class="status-dot" aria-hidden="true"></span>locale</span>
          </header>

          <div class="artifact-main">
            <div class="artifact-body">
              <div class="mini-panel">
                <p class="mini-label">Contesto</p>
                <p>
                  Follow-up territoriale, cronicità e documentazione dispersa. Il punto non è
                  automatizzare la cura: è rendere più chiaro cosa merita attenzione.
                </p>
              </div>

              <div class="method-list" aria-label="Metodo">
                <div class="method-row">
                  <span class="method-index">01</span>
                  <span class="method-text">
                    <strong>Raccolgo il segnale clinico</strong>
                    <span>Problema ricorrente, documento o dato che torna nel lavoro quotidiano.</span>
                  </span>
                </div>
                <div class="method-row">
                  <span class="method-index">02</span>
                  <span class="method-text">
                    <strong>Riconcilio le fonti</strong>
                    <span>Distinguo dato, interpretazione e limite prima di trasformarli in azione.</span>
                  </span>
                </div>
                <div class="method-row">
                  <span class="method-index">03</span>
                  <span class="method-text">
                    <strong>Lascio una traccia rivedibile</strong>
                    <span>Una nota utile al medico, non un output chiuso da accettare in fretta.</span>
                  </span>
                </div>
              </div>
            </div>

            <aside class="artifact-rail" aria-label="Stato della traccia">
              <div class="rail-group">
                <p class="rail-label">Dato</p>
                <p class="rail-value">sul dispositivo</p>
                <p class="rail-note">nessun cloud clinico</p>
              </div>
              <div class="rail-group">
                <p class="rail-label">Revisione</p>
                <p class="rail-value">umana</p>
                <p class="rail-note">prima di ogni scelta</p>
              </div>
              <div class="rail-group">
                <p class="rail-label">Chiarezza</p>
                <div class="rail-meter" aria-hidden="true">
                  <span style="--w:82%;--c:var(--mint)"></span>
                  <span style="--w:64%;--c:var(--azure)"></span>
                  <span style="--w:48%;--c:var(--amber)"></span>
                </div>
              </div>
            </aside>
          </div>

          <div class="evidence" aria-label="Evidenze sintetiche">
            <div class="evidence-row">
              <b>Fonte</b>
              <span>cartella locale, nota clinica, documento allegato</span>
              <em>sintetico</em>
            </div>
            <div class="evidence-row">
              <b>Limite</b>
              <span>nessuna inferenza nascosta, nessuna promessa diagnostica</span>
              <em>visibile</em>
            </div>
            <div class="evidence-row">
              <b>Azione</b>
              <span>prossimo controllo, domanda aperta, dato da confermare</span>
              <em>rivedibile</em>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section id="bio">
    <div class="wrap">
      <div class="bio-grid reveal">
        <div class="bio-side">
          <img class="bio-photo" src="/avatar.svg" alt="Foto di Leonardo Pegollo" width="200" height="200" loading="lazy" />
          <p class="bio-role">Leonardo Pegollo</p>
          <p class="bio-tag">Medico di distretto · Milano</p>
          <dl class="bio-meta">
            <div><dt>Digitali</dt><dd>SQL · Python · R · Astro</dd></div>
            <div><dt>Analogici</dt><dd>Eko Health 500 · abbassalingua</dd></div>
          </dl>
          <div style="margin-top:18px">
            <SocialLinks variant="icons" align="center" />
          </div>
        </div>
        <div class="bio-body">
          <div class="kicker">Bio</div>
          <h2>In due paragrafi.</h2>
          <p>
            Faccio il medico di distretto a Milano. Da sempre lavoro su sanità
            territoriale, pazienti complessi e domiciliarità: la parte di sistema dove
            la cura non si esaurisce nella prescrizione, ma comincia lì. Sono fresco di
            master in <em>gestione delle aziende sociosanitarie</em>. Un master che mi
            ha lasciato addosso un certo modo di guardare i processi.
          </p>
          <p>
            Mi interessa il punto in cui l'operatività clinica incontra dati,
            codice e strumenti di lavoro: capire cosa fare, come farlo, e come
            renderlo pratico senza perdere di vista la cura. Da qui
            <a href="/mediflow" class="link-ink">MediFlow</a> e da qui questo sito.
          </p>
          <p class="muted" style="font-size:14.5px">
            La <a href="/about" class="link-ink">versione lunga della bio</a> è nella pagina dedicata.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="cosa-faccio">
    <div class="wrap">
      <SectionHead
        kicker="Cosa faccio"
        heading="Tre cose, niente di più."
        lead="Ogni progetto qui presente nasce da un problema reale incontrato sul lavoro. Niente esercizi di stile."
      />

      <div class="taxonomy-grid reveal">
        <a class="taxonomy-link" href="/mediflow" style="--tax:var(--mint)">
          <span class="tax-top"><span>01</span><span class="tax-mark" aria-hidden="true"></span></span>
          <strong>MediFlow</strong>
          <p>Cartella clinica locale e cifrata, AI sul dispositivo. Standard ICD-11 e FHIR R4.</p>
          <span class="tax-foot">White paper →</span>
        </a>
        <div class="taxonomy-link is-pending" style="--tax:var(--azure)" aria-disabled="true">
          <span class="tax-top"><span>02</span><span class="tax-mark" aria-hidden="true"></span></span>
          <strong>Note dal territorio</strong>
          <p>Letture dei dati territoriali: cronicità, appropriatezza e aspettative di chi è in cura.</p>
          <span class="tax-foot">In arrivo</span>
        </div>
        <a class="taxonomy-link" href="/blog" style="--tax:var(--amber)">
          <span class="tax-top"><span>03</span><span class="tax-mark" aria-hidden="true"></span></span>
          <strong>Note di lavoro</strong>
          <p>Decisioni, audit e processi. Niente trend, niente buzz.</p>
          <span class="tax-foot">Blog →</span>
        </a>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section id="ultimi-post">
      <div class="wrap">
        <SectionHead kicker="Dal blog" heading="Ultimi appunti." />
        <div class="post-list reveal">
          {posts.map((p) => (
            <a class="post-link" href={`/blog/${p.slug}`}>
              <div class="meta">{fmt(p.data.pubDate)}</div>
              <div>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
              </div>
              <div class="arrow" aria-hidden="true">→</div>
            </a>
          ))}
        </div>
        <div style="margin-top:24px">
          <a class="btn ghost" href="/blog">Tutti i post →</a>
        </div>
      </div>
    </section>
  )}

  <section id="chiusura">
    <div class="wrap-narrow">
      <PullQuote cite="Promemoria personale">«Scrivere quello che hai capito è il modo più rapido per scoprire cosa non avevi capito.»</PullQuote>
    </div>
  </section>
</BaseLayout>

<style>
  .hero{ padding:0 0 64px; }
  .hero-grid{
    display:grid;
    grid-template-columns:minmax(0, 1fr) minmax(360px, 500px);
    gap:52px;
    align-items:center;
  }
  .hero-copy{
    position:relative;
    padding:0;
  }
  .role-line{
    margin:0 0 18px;
    font-family:var(--font-technical);
    color:var(--ink-2);
    font-size:.82rem;
    text-transform:uppercase;
    letter-spacing:.08em;
  }
  .hero h1{ margin:0 0 24px; max-width:10ch; }
  .hero h1 .h-mute{ display:block; max-width:12ch; }
  .hero .lead{ max-width:620px; margin-top:0; font-size:1.18rem; }
  .hero-notes{
    display:flex;
    flex-wrap:wrap;
    gap:9px 18px;
    margin-top:22px;
    color:var(--ink-2);
    font:700 .76rem/1.2 var(--font-technical);
    text-transform:uppercase;
  }
  .hero-notes span{
    white-space:nowrap;
  }
  .cta-row{
    display:flex;
    gap:10px;
    margin-top:26px;
    flex-wrap:wrap;
  }
  .social-row{ margin-top:24px; }

  /* === Appunto operativo · clinical artifact === */
  .artifact{
    position:relative;
    border-radius:var(--r-media);
    border:1px solid rgba(17,20,23,.11);
    background:
      linear-gradient(180deg, rgba(255,255,255,.94), rgba(244,246,247,.92)),
      var(--surface);
    box-shadow:var(--sh-card);
    overflow:hidden;
  }
  .artifact::before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    background-image:
      linear-gradient(rgba(17,20,23,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(17,20,23,.035) 1px, transparent 1px);
    background-size:24px 24px;
    mask-image:linear-gradient(180deg, rgba(0,0,0,.1), rgba(0,0,0,.22) 32%, transparent 78%);
    -webkit-mask-image:linear-gradient(180deg, rgba(0,0,0,.1), rgba(0,0,0,.22) 32%, transparent 78%);
  }
  .artifact-shell{
    position:relative;
    margin:10px;
    border-radius:12px;
    border:1px solid rgba(255,255,255,.8);
    background:rgba(255,255,255,.88);
    overflow:hidden;
  }
  .artifact-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    min-height:56px;
    padding:12px 14px;
    border-bottom:1px solid var(--line);
    background:linear-gradient(180deg, rgba(255,255,255,.92), rgba(244,246,247,.78));
  }
  .artifact-title{ min-width:0; }
  .artifact-title strong{
    display:block;
    font:780 15px/1.25 var(--font-display);
    color:var(--ink-0);
  }
  .artifact-title span{
    display:block;
    margin-top:2px;
    color:var(--ink-1);
    font:12px/1.35 var(--font-technical);
  }
  /* .status-pill / .status-dot ora vivono in global.css (motivo firma riusabile). */
  .artifact-main{
    display:grid;
    grid-template-columns:minmax(0,1fr) 138px;
    min-height:390px;
  }
  .artifact-body{ padding:15px; min-width:0; }
  .mini-panel{
    margin-bottom:12px;
    padding:12px;
    border:1px solid var(--line);
    border-radius:var(--r-row);
    background:rgba(244,246,247,.72);
  }
  .mini-label{
    margin:0 0 7px;
    color:var(--ink-1);
    font:740 12px/1.25 var(--font-technical);
    text-transform:uppercase;
  }
  .mini-panel p{
    margin:0;
    color:var(--ink-1);
    font-size:14px;
    line-height:1.5;
  }
  .method-list{
    display:grid;
    gap:8px;
    margin-top:10px;
  }
  .method-row{
    display:grid;
    grid-template-columns:34px minmax(0,1fr);
    gap:10px;
    align-items:start;
    padding:10px;
    border:1px solid rgba(17,20,23,.075);
    border-radius:var(--r-row);
    background:var(--surface);
    transition:background var(--dur-1) var(--ease), border-color var(--dur-1) var(--ease);
  }
  .method-row:hover{
    background:#fbfcfc;
    border-color:rgba(14,110,92,.22);
  }
  .method-index{
    width:26px;
    height:26px;
    display:grid;
    place-items:center;
    border-radius:8px;
    background:var(--surface-3);
    color:var(--ink-1);
    font:780 12px/1 var(--font-technical);
  }
  .method-text{ min-width:0; }
  .method-text strong{
    display:block;
    margin-bottom:2px;
    font-size:14px;
    line-height:1.35;
    color:var(--ink-0);
  }
  .method-text span{
    display:block;
    color:var(--ink-1);
    font-size:13px;
    line-height:1.45;
  }
  .artifact-rail{
    border-left:1px solid var(--line);
    background:rgba(244,246,247,.54);
    padding:12px;
    min-width:0;
  }
  .rail-group + .rail-group{
    margin-top:16px;
    padding-top:16px;
    border-top:1px solid var(--line);
  }
  .rail-label{
    margin:0 0 8px;
    color:var(--ink-1);
    font:740 11.5px/1.25 var(--font-technical);
    text-transform:uppercase;
  }
  .rail-value{
    margin:0;
    color:var(--ink-0);
    font:760 13px/1.35 var(--font-body);
  }
  .rail-note{
    margin:4px 0 0;
    color:var(--ink-1);
    font-size:12.5px;
    line-height:1.35;
  }
  .rail-meter{
    display:grid;
    gap:5px;
    margin-top:10px;
  }
  .rail-meter span{
    height:6px;
    border-radius:999px;
    background:var(--line);
    overflow:hidden;
  }
  .rail-meter span::before{
    content:"";
    display:block;
    height:100%;
    width:var(--w, 60%);
    border-radius:inherit;
    background:var(--c, var(--mint));
  }
  .evidence{
    display:grid;
    gap:8px;
    padding:0 15px 15px;
  }
  .evidence-row{
    display:grid;
    grid-template-columns:84px minmax(0,1fr) 74px;
    gap:10px;
    align-items:center;
    min-height:40px;
    padding:8px 10px;
    border:1px solid var(--line);
    border-radius:var(--r-row);
    background:rgba(255,255,255,.86);
    color:var(--ink-1);
    font-size:13px;
  }
  .evidence-row b{
    color:var(--ink-0);
    font:740 12px/1.25 var(--font-technical);
  }
  .evidence-row span{ min-width:0; }
  .evidence-row em{
    justify-self:end;
    color:var(--ink-1);
    font:700 11.5px/1.25 var(--font-technical);
    font-style:normal;
  }

  /* === Tassonomia compatta · ogni ingresso con una prova === */
  .taxonomy-grid{
    display:grid;
    grid-template-columns:repeat(3, minmax(0,1fr));
    gap:10px;
  }
  .taxonomy-link{
    display:flex;
    flex-direction:column;
    gap:9px;
    min-height:150px;
    min-width:0;
    padding:16px;
    border:1px solid var(--line);
    border-radius:var(--r-row);
    text-decoration:none;
    color:inherit;
    background:var(--surface);
    box-shadow:var(--sh-pill);
    transition:box-shadow var(--dur-1) var(--ease), border-color var(--dur-1) var(--ease);
  }
  a.taxonomy-link:hover{
    border-color:var(--line-strong);
    box-shadow:var(--sh-card);
  }
  .tax-top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    color:var(--ink-1);
    font:740 12px/1.25 var(--font-technical);
  }
  .tax-mark{
    width:9px;
    height:9px;
    border-radius:999px;
    background:var(--tax, var(--mint));
  }
  .taxonomy-link strong{
    display:block;
    color:var(--ink-0);
    font:790 17px/1.28 var(--font-display);
  }
  .taxonomy-link p{
    margin:0;
    color:var(--ink-1);
    font-size:13.5px;
    line-height:1.5;
  }
  .tax-foot{
    margin-top:auto;
    color:var(--mint);
    font:700 .76rem/1 var(--font-technical);
  }
  .taxonomy-link.is-pending{
    background:var(--surface-2);
    box-shadow:none;
    cursor:default;
  }
  .taxonomy-link.is-pending .tax-foot{ color:var(--ink-1); }

  /* === Sezione bio (home) === */
  .bio-grid{
    display:grid;
    grid-template-columns: 260px 1fr;
    gap:48px;
    align-items:start;
    padding:0;
    background:transparent; border:none;
    backdrop-filter:none; -webkit-backdrop-filter:none;
  }
  @media (max-width:780px){
    .bio-grid{ grid-template-columns:1fr; gap:32px; }
  }
  .bio-side{
    text-align:center;
    padding:28px 24px;
    border:1px solid var(--line);
    border-radius:var(--r-card);
    background:var(--surface);
    box-shadow:var(--sh-card);
  }
  @media (max-width:780px){ .bio-side{ text-align:left; padding:24px; } }
  .bio-photo{
    width:144px; height:144px; border-radius:50%;
    margin:0 auto 18px; display:block;
    object-fit:cover;
    background:#fff;
    padding:3px;
    background-image:linear-gradient(#fff, #fff), linear-gradient(135deg, var(--mint) 0%, var(--surface-3) 100%);
    background-origin:border-box;
    background-clip:content-box, border-box;
    box-shadow:var(--sh-pill);
  }
  @media (max-width:780px){ .bio-photo{ margin:0 0 18px; } }
  .bio-role{
    font-family:var(--font-display);
    font-size:20px; font-weight:500; color:var(--ink-0); margin:0 0 4px;
  }
  .bio-tag{
    font-family:var(--font-technical);
    font-size:12px; color:var(--ink-2); margin:0 0 20px;
  }
  .bio-meta{
    list-style:none; padding:18px 0 0; margin:0;
    text-align:left;
    border-top:1px solid var(--line);
    display:flex; flex-direction:column; gap:10px;
  }
  .bio-meta div{
    display:grid;
    grid-template-columns:80px 1fr;
    gap:10px;
    font-size:13.5px;
    color:var(--ink-1);
  }
  .bio-meta dt{
    font-family:var(--font-technical);
    font-size:11px; text-transform:uppercase;
    color:var(--ink-2);
    margin:0; padding-top:2px;
  }
  .bio-meta dd{ margin:0; }

  .bio-body h2{ margin-top:0; }
  .bio-body p{ margin-bottom:14px; }
  .bio-body a{ color:var(--ink-0); }

  /* Collapse the two-column hero before the sidebar+hero crush band (901-1040px):
     two-column only survives where the copy track stays readable. */
  @media (max-width:1180px){
    .hero-grid{ grid-template-columns:1fr; gap:38px; }
    .artifact{ max-width:620px; }
  }
  /* Stack the artifact internals (body over rail; rail becomes a 3-up row) once
     the surface narrows — mirrors the prototype's 1040 rules, retargeted to 900. */
  @media (max-width:900px){
    .artifact-main{ grid-template-columns:1fr; }
    .artifact-rail{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:10px;
      border-left:0;
      border-top:1px solid var(--line);
    }
    .rail-group + .rail-group{ margin-top:0; padding-top:0; border-top:0; }
  }
  @media (max-width:720px){
    .method-row{ grid-template-columns:30px minmax(0,1fr); }
    .artifact-shell{ margin:7px; }
  }
  @media (max-width:680px){
    .taxonomy-grid{ grid-template-columns:1fr; }
    .artifact-head{ flex-direction:column; align-items:flex-start; }
  }
  @media (max-width:560px){
    .artifact-rail{ grid-template-columns:1fr; }
    .evidence-row{ grid-template-columns:1fr; gap:4px; }
    .evidence-row em{ justify-self:start; }
  }
</style>
