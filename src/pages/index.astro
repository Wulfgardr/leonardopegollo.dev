---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SocialLinks from '~/components/SocialLinks.astro';
import { getCollection } from 'astro:content';

// Ultimi tre post del blog, in ordine di data decrescente.
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="leonardopegollo.dev"
  description="Leonardo Pegollo: medico di distretto a Milano, mani anche dentro il codice. Sanità territoriale, dati, prodotto clinico locale."
>
  <section class="hero">
    <div class="wrap">
      <span class="eyebrow"><span class="dot"></span> Milano · Maggio 2026 · Vol. 1</span>
      <h1 class="gradient-title" style="margin-top:18px">
        Medico di distretto,<br/>
        <em>mani anche dentro il codice.</em>
      </h1>
      <p class="lead" style="max-width:680px; margin-top:24px">
        Mi chiamo Leo. Faccio il medico di distretto a Milano: sanità territoriale,
        pazienti complessi, domiciliarità. La parte di sistema dove la cura non
        finisce con la prescrizione, ma comincia lì. In parallelo metto le mani
        dentro <a href="/mediflow" class="link-ink">MediFlow</a> (nome temporaneo),
        un applicativo clinico nato per me e, aspirazionalmente, per chiunque
        voglia uno strumento di lavoro che non chieda di affidare i dati a terzi.
      </p>
      <p class="lead muted" style="max-width:680px; margin-top:4px">
        Qui scrivo di cosa sia la sanità nell'epoca del «codice democratico»,
        e del rigore poco democratico che deve circondarla.
      </p>
      <div class="cta-row">
        <a class="btn primary" href="/mediflow">White paper di MediFlow <span aria-hidden="true">→</span></a>
        <a class="btn ghost" href="/blog">Vai al blog</a>
        <a class="btn ghost" href="/about">Bio completa</a>
      </div>

      <div style="margin-top:28px">
        <SocialLinks variant="pills" />
      </div>

      <div class="strip" aria-hidden="true">
        <span><b>Local-first</b></span>
        <span><b>Open source</b></span>
        <span><b>Niente analytics di terze parti</b></span>
        <span><b>Niente sponsor</b></span>
      </div>
    </div>
  </section>

  <section id="bio">
    <div class="wrap">
      <div class="bio-grid reveal">
        <div class="bio-side">
          <img class="bio-photo" src="/avatar.svg" alt="Foto di Leonardo Pegollo" width="200" height="200" loading="lazy" />
          <p class="bio-role">Leonardo Pegollo</p>
          <p class="bio-tag">Medico di distretto · Milano</p>
          <dl class="bio-meta">
            <div><dt>Digitali</dt><dd>SQL · Python · R · Astro</dd></div>
            <div><dt>Analogici</dt><dd>Eko Health 500 · abbassalingua</dd></div>
          </dl>
          <div style="margin-top:18px">
            <SocialLinks variant="icons" align="center" />
          </div>
        </div>
        <div class="bio-body">
          <div class="kicker">Bio</div>
          <h2>In due paragrafi.</h2>
          <p>
            Faccio il medico di distretto a Milano. Da sempre lavoro su sanità
            territoriale, pazienti complessi e domiciliarità: la parte di sistema dove
            la cura non si esaurisce nella prescrizione, ma comincia lì. Sono fresco di
            master in <em>gestione delle aziende sociosanitarie</em>. Un master che mi
            ha lasciato addosso un certo modo di guardare i processi.
          </p>
          <p>
            C'è qualcosa di intrigante nel mettere le mani contemporaneamente
            nell'operatività clinica e dentro un applicativo: ragionare su cosa fare,
            come farlo, e come renderlo pratico. Per me, e poi (se viene bene) per chi
            voglia uno strumento simile per la propria attività clinica. Da qui
            <a href="/mediflow" class="link-ink">MediFlow</a> e da qui questo sito.
          </p>
          <p class="muted" style="font-size:14.5px">
            La <a href="/about" class="link-ink">versione lunga della bio</a> è nella pagina dedicata.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="cosa-faccio">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="kicker">Cosa faccio</div>
        <h2>Tre cose, niente di più.</h2>
        <p class="lead">Ogni progetto qui presente nasce da un problema reale incontrato sul lavoro. Niente esercizi di stile.</p>
      </div>

      <div class="grid cols-3 reveal">
        <a class="card" href="/mediflow" style="text-decoration:none">
          <span class="ord">01</span>
          <div class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 3v6a4 4 0 0 0 8 0V3"/>
              <path d="M9 13v3a4 4 0 0 0 8 0v-2"/>
              <circle cx="17" cy="11" r="2"/>
            </svg>
          </div>
          <h3>MediFlow</h3>
          <p>Cartella clinica locale, cifrata, con AI sul dispositivo. Standard ICD-11 e FHIR R4. Per chi esercita in autonomia o piccoli ambulatori.</p>
          <p class="card-cta">Leggi il white paper <span aria-hidden="true">→</span></p>
        </a>
        <div class="card">
          <span class="ord">02</span>
          <div class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 18h18"/>
              <rect x="5" y="12" width="3" height="6"/>
              <rect x="10.5" y="8" width="3" height="10"/>
              <rect x="16" y="4" width="3" height="14"/>
            </svg>
          </div>
          <h3>Note dal territorio</h3>
          <p>Letture dei dati territoriali che si possono discutere insieme. Grandi e piccoli temi della clinica quotidiana nella gestione della cronicità: indicatori, appropriatezza, aspettative di chi è in cura. Tono informale, mai approssimativo.</p>
          <p class="card-cta muted">In arrivo nel blog. Qualche slide ci sta.</p>
        </div>
        <div class="card">
          <span class="ord">03</span>
          <div class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 4h11l3 3v13H5z"/>
              <path d="M8 9h8M8 13h8M8 17h5"/>
            </svg>
          </div>
          <h3>Note di lavoro</h3>
          <p>Riflessioni asciutte su decisioni, audit, processi, accreditamento. Niente trend, niente buzz.</p>
          <p class="card-cta"><a href="/blog" class="link-ink">Vai al blog →</a></p>
        </div>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section id="ultimi-post">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="kicker">Dal blog</div>
          <h2>Ultimi appunti.</h2>
        </div>
        <div class="post-list reveal">
          {posts.map((p) => (
            <a class="post-link" href={`/blog/${p.slug}`}>
              <div class="meta">{fmt(p.data.pubDate)}</div>
              <div>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
              </div>
              <div class="arrow" aria-hidden="true">→</div>
            </a>
          ))}
        </div>
        <div style="margin-top:24px">
          <a class="btn ghost" href="/blog">Tutti i post →</a>
        </div>
      </div>
    </section>
  )}

  <section id="chiusura">
    <div class="wrap-narrow">
      <div class="pull reveal">
        «Scrivere quello che hai capito è il modo più rapido per scoprire cosa non avevi capito.»
        <small>Promemoria personale</small>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero{ padding:100px 0 64px; }
  .hero h1{ margin:18px 0 18px; }
  .hero h1 em{
    font-style:italic;
    color:var(--paper);
    -webkit-text-fill-color:var(--paper);
    background:none;
  }

  .cta-row{
    display:flex; gap:10px; margin-top:32px; flex-wrap:wrap;
  }

  /* Link in linea con sottolineatura tipo penna */
  :global(.link-ink){
    color:var(--ink-0);
    text-decoration:underline;
    text-decoration-color:rgba(134,211,177,.55);
    text-decoration-thickness:1px;
    text-underline-offset:4px;
    transition:text-decoration-color .2s ease;
  }
  :global(.link-ink:hover){
    text-decoration-color:var(--mint);
  }

  .card-cta{
    font-size:13px; margin-top:14px; color:var(--mint);
    font-family:var(--mono); letter-spacing:.3px;
  }
  .card-cta a{ color:var(--mint); text-decoration:none; }

  /* === Sezione bio (home) === */
  .bio-grid{
    display:grid;
    grid-template-columns: 260px 1fr;
    gap:48px;
    align-items:start;
    padding:0;
    background:transparent; border:none;
    backdrop-filter:none; -webkit-backdrop-filter:none;
  }
  @media (max-width:780px){
    .bio-grid{ grid-template-columns:1fr; gap:32px; }
  }
  .bio-side{
    text-align:center;
    padding:28px 24px;
    border:1px solid var(--rule);
    border-radius:var(--r-2);
    background:rgba(241,234,217,.025);
  }
  @media (max-width:780px){ .bio-side{ text-align:left; padding:24px; } }
  .bio-photo{
    width:144px; height:144px; border-radius:50%;
    margin:0 auto 18px; display:block;
    object-fit:cover;
    background:#0a1018;
    padding:3px;
    background-image:linear-gradient(#0d1217, #0d1217), linear-gradient(135deg, var(--mint) 0%, var(--paper) 60%, var(--amber) 100%);
    background-origin:border-box;
    background-clip:content-box, border-box;
    box-shadow:0 0 0 1px rgba(241,234,217,.06), 0 18px 36px -18px rgba(0,0,0,.6);
  }
  @media (max-width:780px){ .bio-photo{ margin:0 0 18px; } }
  .bio-role{
    font-family:var(--serif);
    font-size:20px; font-weight:500; color:var(--ink-0); margin:0 0 4px;
  }
  .bio-tag{
    font-family:var(--mono);
    font-size:12px; color:var(--ink-2); margin:0 0 20px;
    letter-spacing:.5px;
  }
  .bio-meta{
    list-style:none; padding:18px 0 0; margin:0;
    text-align:left;
    border-top:1px solid var(--rule);
    display:flex; flex-direction:column; gap:10px;
  }
  .bio-meta div{
    display:grid;
    grid-template-columns:80px 1fr;
    gap:10px;
    font-size:13.5px;
    color:var(--ink-1);
  }
  .bio-meta dt{
    font-family:var(--mono);
    font-size:11px; text-transform:uppercase; letter-spacing:1.5px;
    color:var(--ink-2);
    margin:0; padding-top:2px;
  }
  .bio-meta dd{ margin:0; }

  .bio-body h2{ margin-top:0; }
  .bio-body p{ margin-bottom:14px; }
  .bio-body a{ color:var(--ink-0); }
</style>
