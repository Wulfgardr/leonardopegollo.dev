---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SocialLinks from '~/components/SocialLinks.astro';
import { getCollection } from 'astro:content';

// Ultimi tre post del blog, in ordine di data decrescente.
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="leonardopegollo.dev"
  description="Leonardo Pegollo: medico di distretto a Milano, mani anche dentro il codice. Sanità territoriale, dati, prodotto clinico locale."
>
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy reveal">
        <p class="role-line">Medico di distretto · Milano</p>
        <h1 class="gradient-title">Leonardo Pegollo <span class="h-mute">medico, dati e qualche riga di codice.</span></h1>
        <p class="lead">
          Faccio il medico di distretto. Lavoro con pazienti complessi,
          domiciliarità e sanità territoriale; quando un problema ritorna spesso,
          provo a capirlo anche con il codice. Da lì nasce
          <a href="/mediflow" class="link-ink">MediFlow</a>, una cartella clinica
          <span class="sig">locale</span> che tiene i dati sul computer di chi cura.
        </p>
        <p class="lead muted">
          Qui tengo appunti su lavoro clinico, dati, processi e piccoli pezzi di
          software che possono aiutare, senza far finta che risolvano tutto.
        </p>
        <div class="chip-row hero-chips" aria-label="Principi tecnici">
          <span class="chip">Dati in locale</span>
          <span class="chip">Niente analytics</span>
          <span class="chip">Standard aperti</span>
          <span class="chip">AI sul dispositivo</span>
        </div>
        <div class="cta-row">
          <a class="btn btn-primary" href="/mediflow">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12h4l2 5 3-10 2 5h7" /></svg>
            Leggi MediFlow
          </a>
          <a class="btn btn-ghost" href="/blog">Blog</a>
          <a class="btn btn-ghost" href="/about">Bio</a>
        </div>
        <div class="social-row">
          <SocialLinks variant="pills" />
        </div>
      </div>

      <aside class="media-frame hero-frame reveal" aria-label="Promemoria sintetico MediFlow">
        <div class="inner hero-system clinical-monitor">
          <div class="system-head">
            <span>MediFlow</span>
            <span>in breve</span>
          </div>
          <svg viewBox="0 0 520 420" role="img" aria-labelledby="system-title system-desc">
            <title id="system-title">Promemoria locale di MediFlow</title>
            <desc id="system-desc">I dati restano sul Mac, cifrati, con AI locale e uscita in formati standard.</desc>
            <defs>
              <linearGradient id="flowSignal" x1="0" x2="1" y1="0" y2="1">
                <stop stop-color="var(--mint)" />
                <stop offset="1" stop-color="var(--signal)" />
              </linearGradient>
            </defs>
            <g class="rail">
              <path d="M260 86v248"/>
              <path d="M152 158h216"/>
              <path d="M152 260h216"/>
            </g>
            <g class="node primary-node">
              <rect x="184" y="34" width="152" height="72" rx="12"/>
              <text x="260" y="66" text-anchor="middle">Sul Mac</text>
              <text x="260" y="86" text-anchor="middle">dati cifrati</text>
            </g>
            <g class="node">
              <rect x="44" y="132" width="152" height="72" rx="12"/>
              <text x="120" y="164" text-anchor="middle">Scheda</text>
              <text x="120" y="184" text-anchor="middle">nel browser</text>
            </g>
            <g class="node">
              <rect x="324" y="132" width="152" height="72" rx="12"/>
              <text x="400" y="164" text-anchor="middle">AI locale</text>
              <text x="400" y="184" text-anchor="middle">se serve</text>
            </g>
            <g class="node">
              <rect x="44" y="234" width="152" height="72" rx="12"/>
              <text x="120" y="266" text-anchor="middle">Export</text>
              <text x="120" y="286" text-anchor="middle">FHIR R4</text>
            </g>
            <g class="node">
              <rect x="324" y="234" width="152" height="72" rx="12"/>
              <text x="400" y="266" text-anchor="middle">SISS/FSE</text>
              <text x="400" y="286" text-anchor="middle">a mano</text>
            </g>
            <g class="node primary-node">
              <rect x="184" y="332" width="152" height="54" rx="12"/>
              <text x="260" y="364" text-anchor="middle">niente invii nascosti</text>
            </g>
          </svg>
          <div class="system-foot">
            <span>No analytics</span>
            <span>No cloud clinico</span>
            <span>Codice aperto</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section id="bio">
    <div class="wrap">
      <div class="bio-grid reveal">
        <div class="bio-side">
          <img class="bio-photo" src="/avatar.svg" alt="Foto di Leonardo Pegollo" width="200" height="200" loading="lazy" />
          <p class="bio-role">Leonardo Pegollo</p>
          <p class="bio-tag">Medico di distretto · Milano</p>
          <dl class="bio-meta">
            <div><dt>Digitali</dt><dd>SQL · Python · R · Astro</dd></div>
            <div><dt>Analogici</dt><dd>Eko Health 500 · abbassalingua</dd></div>
          </dl>
          <div style="margin-top:18px">
            <SocialLinks variant="icons" align="center" />
          </div>
        </div>
        <div class="bio-body">
          <div class="kicker">Bio</div>
          <h2>In due paragrafi.</h2>
          <p>
            Faccio il medico di distretto a Milano. Da sempre lavoro su sanità
            territoriale, pazienti complessi e domiciliarità: la parte di sistema dove
            la cura non si esaurisce nella prescrizione, ma comincia lì. Sono fresco di
            master in <em>gestione delle aziende sociosanitarie</em>. Un master che mi
            ha lasciato addosso un certo modo di guardare i processi.
          </p>
          <p>
            C'è qualcosa di intrigante nel mettere le mani contemporaneamente
            nell'operatività clinica e dentro un applicativo: ragionare su cosa fare,
            come farlo, e come renderlo pratico. Per me, e poi (se viene bene) per chi
            voglia uno strumento simile per la propria attività clinica. Da qui
            <a href="/mediflow" class="link-ink">MediFlow</a> e da qui questo sito.
          </p>
          <p class="muted" style="font-size:14.5px">
            La <a href="/about" class="link-ink">versione lunga della bio</a> è nella pagina dedicata.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="cosa-faccio">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="kicker">Cosa faccio</div>
        <h2>Tre cose, niente di più.</h2>
        <p class="lead">Ogni progetto qui presente nasce da un problema reale incontrato sul lavoro. Niente esercizi di stile.</p>
      </div>

      <div class="editorial-list reveal">
        <a class="editorial-row" href="/mediflow">
          <span class="idx">01</span>
          <span class="row-title">MediFlow</span>
          <span class="row-body">Cartella clinica locale, cifrata, con AI sul dispositivo. Standard ICD-11 e FHIR R4.</span>
          <span class="row-action">White paper →</span>
        </a>
        <div class="editorial-row">
          <span class="idx">02</span>
          <span class="row-title">Note dal territorio</span>
          <span class="row-body">Letture dei dati territoriali, cronicità, appropriatezza e aspettative di chi è in cura.</span>
          <span class="row-action muted">In arrivo</span>
        </div>
        <a class="editorial-row" href="/blog">
          <span class="idx">03</span>
          <span class="row-title">Note di lavoro</span>
          <span class="row-body">Decisioni, audit, processi, accreditamento. Niente trend, niente buzz.</span>
          <span class="row-action">Blog →</span>
        </a>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section id="ultimi-post">
      <div class="wrap">
        <div class="section-head reveal">
          <div class="kicker">Dal blog</div>
          <h2>Ultimi appunti.</h2>
        </div>
        <div class="post-list reveal">
          {posts.map((p) => (
            <a class="post-link" href={`/blog/${p.slug}`}>
              <div class="meta">{fmt(p.data.pubDate)}</div>
              <div>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
              </div>
              <div class="arrow" aria-hidden="true">→</div>
            </a>
          ))}
        </div>
        <div style="margin-top:24px">
          <a class="btn ghost" href="/blog">Tutti i post →</a>
        </div>
      </div>
    </section>
  )}

  <section id="chiusura">
    <div class="wrap-narrow">
      <div class="pull reveal">
        «Scrivere quello che hai capito è il modo più rapido per scoprire cosa non avevi capito.»
        <small>Promemoria personale</small>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero{ padding:0 0 64px; }
  .hero-grid{
    display:grid;
    grid-template-columns:minmax(0, 1fr) minmax(360px, 500px);
    gap:52px;
    align-items:center;
  }
  .hero-copy{
    position:relative;
    padding:0;
  }
  .hero-copy::before{ display:none; }
  .role-line{
    margin:0 0 18px;
    font-family:var(--font-technical);
    color:var(--ink-2);
    font-size:.82rem;
    text-transform:uppercase;
    letter-spacing:.08em;
  }
  .hero h1{ margin:0 0 24px; max-width:10ch; }
  .hero h1 .h-mute{ display:block; max-width:12ch; }
  .hero .lead{ max-width:620px; margin-top:0; font-size:1.18rem; }
  .hero-chips{ margin-top:22px; }
  .cta-row{
    display:flex;
    gap:10px;
    margin-top:26px;
    flex-wrap:wrap;
  }
  .social-row{ margin-top:24px; }

  .hero-system{
    border:0;
    border-radius:14px;
    background:#0d1117;
    box-shadow:none;
    overflow:hidden;
  }
  .system-head,
  .system-foot{
    display:flex;
    justify-content:space-between;
    gap:12px;
    padding:14px 16px;
    font-family:var(--font-technical);
    font-size:.75rem;
    color:#a8b0b8;
    text-transform:uppercase;
    border-bottom:1px solid rgba(230,237,243,.14);
  }
  .system-head span:first-child{ color:#e6edf3; font-weight:700; }
  .system-foot{
    border-top:1px solid rgba(230,237,243,.14);
    border-bottom:0;
    flex-wrap:wrap;
  }
  .hero-system svg{ width:100%; height:auto; display:block; padding:26px 18px 18px; }
  .rail path{
    fill:none;
    stroke:rgba(230,237,243,.18);
    stroke-width:1.2;
  }
  .node rect{
    fill:#111820;
    stroke:rgba(230,237,243,.18);
    stroke-width:1;
    filter:drop-shadow(0 8px 18px rgba(0,0,0,.16));
  }
  .primary-node rect{
    fill:url(#flowSignal);
    stroke:rgba(21,196,122,.72);
  }
  .node text{
    font-family:var(--font);
    font-size:13px;
    fill:#e6edf3;
  }
  .node text + text{
    font-family:var(--font-technical);
    font-size:11px;
    fill:#a8b0b8;
  }
  .primary-node text,
  .primary-node text + text{ fill:#fff; }

  .editorial-list{ display:grid; gap:10px; }
  .editorial-row{
    display:grid;
    grid-template-columns:56px minmax(140px, 220px) minmax(0, 1fr) auto;
    gap:22px;
    align-items:start;
    padding:18px;
    border:1px solid var(--line);
    border-radius:var(--r-card);
    background:var(--surface);
    box-shadow:var(--sh-pill);
    color:inherit;
    text-decoration:none;
    transition:transform var(--dur-1) var(--ease), box-shadow var(--dur-1) var(--ease), border-color var(--dur-1) var(--ease);
  }
  a.editorial-row:hover{
    transform:translateY(-2px);
    box-shadow:var(--sh-card);
    border-color:var(--line-strong);
  }
  .editorial-row .idx,
  .editorial-row .row-action{
    font-family:var(--font-technical);
    font-size:.8rem;
    color:var(--ink-2);
  }
  .editorial-row .row-title{
    color:var(--ink-0);
    font-weight:700;
  }
  .editorial-row .row-body{
    color:var(--ink-1);
    max-width:62ch;
  }
  .editorial-row .row-action{ color:var(--mint); white-space:nowrap; }

  /* === Sezione bio (home) === */
  .bio-grid{
    display:grid;
    grid-template-columns: 260px 1fr;
    gap:48px;
    align-items:start;
    padding:0;
    background:transparent; border:none;
    backdrop-filter:none; -webkit-backdrop-filter:none;
  }
  @media (max-width:780px){
    .bio-grid{ grid-template-columns:1fr; gap:32px; }
  }
  .bio-side{
    text-align:center;
    padding:28px 24px;
    border:1px solid var(--rule);
    border-radius:var(--r-card);
    background:var(--surface);
    box-shadow:var(--sh-card);
  }
  @media (max-width:780px){ .bio-side{ text-align:left; padding:24px; } }
  .bio-photo{
    width:144px; height:144px; border-radius:50%;
    margin:0 auto 18px; display:block;
    object-fit:cover;
    background:#fff;
    padding:3px;
    background-image:linear-gradient(#fff, #fff), linear-gradient(135deg, var(--mint) 0%, var(--bg-3) 100%);
    background-origin:border-box;
    background-clip:content-box, border-box;
    box-shadow:var(--shadow-1);
  }
  @media (max-width:780px){ .bio-photo{ margin:0 0 18px; } }
  .bio-role{
    font-family:var(--font-display);
    font-size:20px; font-weight:500; color:var(--ink-0); margin:0 0 4px;
  }
  .bio-tag{
    font-family:var(--font-technical);
    font-size:12px; color:var(--ink-2); margin:0 0 20px;
  }
  .bio-meta{
    list-style:none; padding:18px 0 0; margin:0;
    text-align:left;
    border-top:1px solid var(--rule);
    display:flex; flex-direction:column; gap:10px;
  }
  .bio-meta div{
    display:grid;
    grid-template-columns:80px 1fr;
    gap:10px;
    font-size:13.5px;
    color:var(--ink-1);
  }
  .bio-meta dt{
    font-family:var(--font-technical);
    font-size:11px; text-transform:uppercase;
    color:var(--ink-2);
    margin:0; padding-top:2px;
  }
  .bio-meta dd{ margin:0; }

  .bio-body h2{ margin-top:0; }
  .bio-body p{ margin-bottom:14px; }
  .bio-body a{ color:var(--ink-0); }

  @media (max-width:900px){
    .hero-grid{ grid-template-columns:1fr; gap:36px; }
    .hero-system{ max-width:560px; }
  }
  @media (max-width:720px){
    .editorial-row{
      grid-template-columns:42px 1fr;
      gap:8px 14px;
    }
    .editorial-row .row-body,
    .editorial-row .row-action{
      grid-column:2;
    }
    .system-head,
    .system-foot{ font-size:.7rem; }
  }
</style>
