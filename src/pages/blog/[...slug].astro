---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <section style="padding-top:50px">
    <div class="wrap-narrow">
      <p style="margin:0 0 24px"><a class="back" href="/blog">← Tutti i post</a></p>

      <article class="article">
        <header>
          <div class="meta">
            {fmt(post.data.pubDate)}
            {post.data.updatedDate && <span> · aggiornato {fmt(post.data.updatedDate)}</span>}
            {post.data.tags.length > 0 && <span> · {post.data.tags.join(' · ')}</span>}
          </div>
          <h1 transition:name={`post-title-${post.slug}`}>{post.data.title}</h1>
          {post.data.description && <p class="standfirst">{post.data.description}</p>}
        </header>
        <Content />
      </article>

      <div class="divider"></div>
      <p style="margin-top:8px"><a class="back" href="/blog">← Torna a tutti i post</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .back{
    color:var(--ink-2); text-decoration:none;
    font-family:var(--font-technical); font-size:13px;
    transition:color var(--dur-1) var(--ease);
  }
  .back:hover{ color:var(--ink-0); }

  .article header .meta{ margin-bottom:18px; }
  .article header .meta + h1{ margin-top:0; }

  .standfirst{
    font-family:var(--font-body);
    font-style:normal;
    font-size:18px;
    line-height:1.62;
    color:var(--ink-1);
    margin:6px 0 0;
    max-width:60ch;
  }

</style>

<style is:global>
  .mermaid{
    margin:28px 0;
    padding:14px;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--r-media);
    overflow:auto;
    text-align:center;
    cursor:zoom-in;
    position:relative;
    box-shadow:var(--sh-card);
    transition:border-color var(--dur-1) var(--ease), box-shadow var(--dur-1) var(--ease), transform var(--dur-1) var(--ease);
  }
  .mermaid:hover{
    border-color:var(--line-strong);
    box-shadow:var(--sh-surface);
    transform:translateY(-2px);
  }
  .mermaid::after{
    content:"clicca per ingrandire";
    position:absolute; top:24px; right:28px;
    padding:6px 9px;
    border-radius:999px;
    background:rgba(13,17,23,.72);
    border:1px solid rgba(230,237,243,.14);
    font-family:var(--font-technical); font-size:10.5px;
    color:#a8b0b8; pointer-events:none;
  }
  .mermaid svg{
    display:block;
    max-width:100%;
    height:auto;
    margin:0 auto;
    padding:18px;
    background:#0d1117;
    border-radius:14px;
  }
  .mermaid svg p{
    color:inherit !important;
    font-weight:inherit;
    line-height:1.3;
  }
  .mermaid svg .label,
  .mermaid svg .nodeLabel,
  .mermaid svg .edgeLabel{
    color:inherit;
  }

  .mermaid-modal{
    position:fixed; inset:0; z-index:9999;
    background:rgba(17,20,23,.88);
    display:flex; align-items:center; justify-content:center;
    padding:24px;
    opacity:0; visibility:hidden;
    transition:opacity .2s ease, visibility .2s ease;
    cursor:zoom-out;
  }
  .mermaid-modal.open{ opacity:1; visibility:visible; }
  .mermaid-modal-inner{
    background:var(--surface);
    border:1px solid rgba(255,255,255,.5);
    border-radius:var(--r-media);
    padding:14px;
    width:96vw; height:92vh;
    max-width:96vw; max-height:92vh;
    overflow:auto;
    box-shadow:0 30px 80px rgba(0,0,0,.6);
  }
  .mermaid-modal-inner svg{
    display:block !important;
    width:100% !important;
    height:auto !important;
    max-width:none !important;
    max-height:none !important;
    padding:24px !important;
    background:#0d1117 !important;
    border-radius:14px !important;
  }
  .mermaid-modal-close{
    position:absolute; top:18px; right:22px;
    width:38px; height:38px; border-radius:50%;
    background:rgba(255,255,255,.14);
    border:1px solid rgba(255,255,255,.32);
    color:#fff;
    font-size:20px; line-height:1;
    display:grid; place-items:center;
    cursor:pointer;
  }
  .mermaid-modal-close:hover{ background:rgba(255,255,255,.22); }
  @media (max-width:560px){
    .mermaid::after{ display:none; }
    .mermaid{ padding:10px; }
    .mermaid svg{ padding:14px; border-radius:12px; }
  }
</style>

<script type="module" is:inline>
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

  // Tema custom coerente con la console visuale del sito.
  mermaid.initialize({
    startOnLoad: false,
    securityLevel: 'loose',
    fontFamily: 'ui-sans-serif, system-ui, -apple-system, sans-serif',
    theme: 'base',
    flowchart: {
      htmlLabels: false,
      curve: 'basis',
      padding: 18,
      nodeSpacing: 60,
      rankSpacing: 70
    },
    sequence: {
      diagramMarginX: 60,
      diagramMarginY: 24,
      actorMargin: 110,
      width: 210,
      boxMargin: 16,
      messageMargin: 38,
      actorFontSize: 15,
      actorFontWeight: 700,
      noteFontSize: 13,
      messageFontSize: 14,
      bottomMarginAdj: 30
    },
    themeVariables: {
      fontSize: '15px',
      background: '#0d1117',
      primaryColor: '#111820',
      primaryTextColor: '#e6edf3',
      primaryBorderColor: '#2d3a44',
      secondaryColor: '#14252d',
      tertiaryColor: '#0e6e5c',
      lineColor: '#52616d',
      textColor: '#e6edf3',
      mainBkg: '#111820',
      nodeBorder: '#2d3a44',
      clusterBkg: '#111820',
      clusterBorder: '#2d3a44',
      edgeLabelBackground: '#0d1117',
      actorBkg: '#111820',
      actorBorder: '#2d3a44',
      actorTextColor: '#e6edf3',
      actorLineColor: '#52616d',
      signalColor: '#a8b0b8',
      signalTextColor: '#e6edf3',
      labelBoxBkgColor: '#111820',
      labelBoxBorderColor: '#2d3a44',
      noteBkgColor: '#14252d',
      noteBorderColor: '#426b7f',
      noteTextColor: '#e6edf3',
      activationBkgColor: '#0e6e5c',
      activationBorderColor: '#15c47a',
    }
  });

  // Astro/Shiki annota il linguaggio sul <pre>, non sul <code>.
  const nodes = document.querySelectorAll('pre[data-language="mermaid"] > code');
  let i = 0;
  for (const code of nodes) {
    const pre = code.parentElement;
    const wrapper = document.createElement('div');
    wrapper.className = 'mermaid';
    wrapper.id = 'mermaid-' + (++i);
    wrapper.textContent = code.textContent;
    pre.replaceWith(wrapper);
  }
  if (i > 0) {
    try { await mermaid.run(); } catch (e) { console.warn('mermaid render', e); }
  }

  // Lightbox: click su un diagramma → modal full-screen
  const modal = document.createElement('div');
  modal.className = 'mermaid-modal';
  modal.innerHTML = '<button class="mermaid-modal-close" aria-label="Chiudi">✕</button><div class="mermaid-modal-inner"></div>';
  document.body.appendChild(modal);
  const modalInner = modal.querySelector('.mermaid-modal-inner');
  const closeModal = () => { modal.classList.remove('open'); modalInner.innerHTML = ''; };
  modal.addEventListener('click', (e) => { if (e.target === modal || e.target.classList.contains('mermaid-modal-close')) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  document.querySelectorAll('.mermaid').forEach((el) => {
    el.addEventListener('click', () => {
      const svg = el.querySelector('svg');
      if (!svg) return;
      const clone = svg.cloneNode(true);
      // Rimuove width/height inline imposti da Mermaid così l'SVG scala col container
      clone.removeAttribute('width');
      clone.removeAttribute('height');
      clone.removeAttribute('style');
      // Forza viewBox come unico determinante delle proporzioni e abilita preserveAspectRatio
      clone.setAttribute('preserveAspectRatio', 'xMidYMid meet');
      modalInner.innerHTML = '';
      modalInner.appendChild(clone);
      modal.classList.add('open');
    });
  });
</script>
