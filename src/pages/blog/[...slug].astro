---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <section style="padding-top:50px">
    <div class="wrap-narrow">
      <p style="margin:0 0 24px"><a class="back" href="/blog">← Tutti i post</a></p>

      <article class="article">
        <header>
          <div class="meta">
            {fmt(post.data.pubDate)}
            {post.data.updatedDate && <span> · aggiornato {fmt(post.data.updatedDate)}</span>}
            {post.data.tags.length > 0 && <span> · {post.data.tags.join(' · ')}</span>}
          </div>
          <h1 transition:name={`post-title-${post.slug}`}>{post.data.title}</h1>
          {post.data.description && <p class="standfirst">{post.data.description}</p>}
        </header>
        <Content />
      </article>

      <div class="divider"></div>
      <p style="margin-top:8px"><a class="back" href="/blog">← Torna a tutti i post</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .back{
    color:var(--ink-2); text-decoration:none;
    font-family:var(--font-technical); font-size:13px;
    transition:color var(--dur-1) var(--ease);
  }
  .back:hover{ color:var(--ink-0); }

  .article header .meta{ margin-bottom:18px; }
  .article header .meta + h1{ margin-top:0; }

  .standfirst{
    font-family:var(--font-body);
    font-style:normal;
    font-size:18px;
    line-height:1.62;
    color:var(--ink-1);
    margin:6px 0 0;
    max-width:60ch;
  }

</style>

<style is:global>
  /* I diagrammi dei post sono SVG statici pre-renderizzati a build-time
     (sorgenti in scripts/diagrams/*.mmd): nessun JS lato client, nessuna
     risorsa di terze parti. Cornice scura coerente con la console del sito. */
  .mermaid{
    margin:28px 0;
    padding:14px;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--r-media);
    overflow:auto;
    text-align:center;
    box-shadow:var(--sh-card);
  }
  .mermaid svg{
    display:block;
    max-width:100%;
    height:auto;
    margin:0 auto;
    padding:18px;
    background:#0d1117;
    border-radius:14px;
  }
  .mermaid svg p{
    color:inherit !important;
    font-weight:inherit;
    line-height:1.3;
  }
  .mermaid svg .label,
  .mermaid svg .nodeLabel,
  .mermaid svg .edgeLabel{
    color:inherit;
  }
  @media (max-width:560px){
    .mermaid{ padding:10px; }
    .mermaid svg{ padding:14px; border-radius:12px; }
  }
</style>
